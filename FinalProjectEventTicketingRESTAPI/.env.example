# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/event-ticketing?retryWrites=true&w=majority

# JWT secret key (use a long, random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# JWT expiry duration
JWT_EXPIRES_IN=7d

# Server port (only used for local development — Netlify ignores this)
PORT=3000

# Environment: development | production
NODE_ENV=development

# --- Netlify deployment notes ---
# Set MONGO_URI, JWT_SECRET, JWT_EXPIRES_IN, and NODE_ENV=production
# in Site settings > Environment variables on your Netlify dashboard.
# Do NOT commit the .env file to Git.
